HF_TOKEN=
GLINER_HOST=http://localhost:8000
MODEL_ID=hivetrace/gliner-guard-uniencoder
MAX_BATCH_SIZE=64
NUM_WORKERS=4

# ONNX runtime settings
ONNX_PRECISION=fp16
ONNX_PROVIDERS=TensorrtExecutionProvider,CUDAExecutionProvider,CPUExecutionProvider
ONNX_PROVIDER_OPTIONS=
ONNX_MODEL_NAME=

# LitServe runtime settings
LITSERVE_MAX_BATCH_SIZE=64
LITSERVE_BATCH_TIMEOUT=0.05
LITSERVE_WORKERS_PER_DEVICE=4
TORCH_MODEL_NAME=hivetrace/gliner-guard-uniencoder
TORCH_DTYPE=bfloat16

# Ray Serve batching (ignored by litserve)
BATCH_WAIT_TIMEOUT=0.05
MAX_CONCURRENT_BATCHES=1
MAX_ONGOING_REQUESTS=200
NUM_REPLICAS=1
NUM_GPUS_PER_REPLICA=1
NUM_CPUS_PER_REPLICA=1
SCHEMA_MODE=minimal
GPU_COUNT=1
RAY_SERVE_THROUGHPUT_OPTIMIZED=0

# Locust
LOCUST_USERS=100
LOCUST_SPAWN_RATE=1
LOCUST_RUN_TIME=15m
LOCUST_USER_THROUGHPUT=5
DATASET=prompts

# Registry (for docker compose build/push)
REGISTRY=harbor.adapstory.com/adapstory
TAG=dev
